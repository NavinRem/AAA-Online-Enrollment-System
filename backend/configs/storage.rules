rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all files (useful for course images, avatars, etc.)
      allow read: if true;
      
      // Only authenticated users can upload files. 
      // Note: Backend functions bypass these rules when using the Admin SDK.
      allow write: if request.auth != null;
    }
  }
}
